# DeFlow Labs — Marketing Website Environment Variables

# Sanity CMS
NUXT_SANITY_PROJECT_ID=
NUXT_SANITY_DATASET=production

# Cloudflare Turnstile (bot protection)
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend (transactional email for contact form)
RESEND_API_KEY=
CONTACT_EMAIL=contact@deflowlabs.io

# Site URL
NUXT_PUBLIC_SITE_URL=https://deflowlabs.io

# Zero-PII salt (for waitlist email hashing)
PII_SALT_SECRET=

# Vercel Postgres (Neon) — auto-injected by Vercel when Storage is connected
POSTGRES_URL=
